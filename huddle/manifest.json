{
  "manifest_version": 3,
  "name": "Meeting Recorder - Google Chat Huddle",
  "version": "3.0.0",
  "description": "Record Google Chat Huddle calls with audio - Auto saves to Downloads",
  "permissions": [
    "activeTab",
    "tabCapture",
    "storage",
    "downloads",
    "tabs"
  ],
  "host_permissions": [
    "https://meet.google.com/*",
    "https://chat.google.com/*",
    "https://mail.google.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Huddle Recorder"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://meet.google.com/*",
        "https://chat.google.com/*",
        "https://mail.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "minimum_chrome_version": "88"
}